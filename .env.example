# OpenAI API Configuration (Whisper STT + GPT-4o-mini for topic classification/feedback)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Anthropic API Configuration (Claude Haiku 4.5 for conversation)
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# Google API Configuration (Gemini Flash TTS — falls back to OpenAI TTS if quota exceeded)
GOOGLE_API_KEY=your-google-api-key-here

# Server Configuration
PORT=3000

# Environment
NODE_ENV=development

# Set to true for detailed logging (system prompt dump, directives, topic classifications)
VERBOSE=false
