# OpenAI API Configuration (Whisper STT + GPT-4o-mini for topic classification/feedback)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# Anthropic API Configuration (Claude Haiku 4.5 for conversation)
ANTHROPIC_API_KEY=sk-ant-api03-your-anthropic-key-here

# Google Cloud Vertex AI Configuration (Gemini Pro TTS)
# Download service account JSON from: https://console.cloud.google.com/iam-admin/serviceaccounts
# The service account needs the "Vertex AI User" role
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Server Configuration
PORT=3000

# Environment
NODE_ENV=development

# Google Drive folder ID for transcript uploads
# Create a folder in Drive, share it with your service account email (Editor access)
# The folder ID is the string after /folders/ in the Drive URL
GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id

# Google Sheets spreadsheet ID for access codes
# Create a sheet with "Access Codes" and "Usage Log" tabs, share with service account email
GOOGLE_SHEETS_ID=your-spreadsheet-id

# Set to true for detailed logging (system prompt dump, directives, topic classifications)
VERBOSE=false
