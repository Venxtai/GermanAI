  "grammar_constraints": {
    "description": "Hard limits on grammatical structures the AI may use",
    "allowed_tenses": [
      "present"
    ],
    "allowed_cases": [
      "nominative"
    ],
    "allowed_persons": [
      "ich",
      "du",
      "er",
      "es",
      "sie_singular",
      "xier",
      "wir",
      "ihr",
      "sie_plural",
      "Sie"
    ],
    "sentence_types": [
      "declarative",
      "w_question"
    ],
    "new_rules_in_this_unit": [
      "Use all six personal pronouns as subjects: ich, du, er/es/sie/xier, wir, ihr, sie/Sie.",
      "Conjugate regular verbs by removing the -en infinitive ending and adding: -e (ich), -st (du), -t (er/es/sie/xier), -en (wir), -t (ihr), -en (sie/Sie).",
      "Ask and answer W-questions about a third person using Wie heißt / Woher kommt / Wo wohnt / Was studiert + er/sie/xier."
    ],
    "forbidden": [
      "tense:Präteritum_haben_sein",
      "tense:Präteritum_modal",
      "tense:Perfekt",
      "tense:Futur_I",
