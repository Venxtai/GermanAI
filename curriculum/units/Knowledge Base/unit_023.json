        "new_rules_in_this_unit": [
            "Form the comparative by adding -er to the adjective and using als for comparisons: \"kleiner als.\"",
            "Express equality with so + adjective + wie: \"so groß wie.\"",
            "Form the superlative with am + adjective + -sten; add -esten after -t or -s sounds.",
            "Add an Umlaut in comparative and superlative for one-syllable adjectives with a, o, or u: alt→älter→am ältesten."
        ],
