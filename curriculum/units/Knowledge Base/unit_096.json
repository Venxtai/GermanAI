            "subordinate_damit",
            "infinitive_um_zu"
        ],
        "new_rules_in_this_unit": [
            "Use damit + subordinate clause (verb at end) to express purpose, especially when the subjects differ: \"…damit seine Kinder nicht rutschen.\"",
            "Use um…zu + infinitive to express purpose when the subject is the same in both clauses; no subject appears in the um…zu clause: \"…um nicht zu rutschen.\""
        ],
        "forbidden": [
            "tense:Futur_I",
            "tense:Präteritum_weak",
