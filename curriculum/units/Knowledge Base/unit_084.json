        "new_rules_in_this_unit": [
            "Use aus + dative for origin from enclosed spaces, countries, and cities; use von + dative for origin from open spaces, persons, activities, or directions.",
            "Use nach for destination to cities and countries without articles; use zu + dative (zum/zur) for destination to specific places and streets.",
            "Give directions using Gehen Sie + geradeaus/links/rechts, Biegen Sie…ab, Gehen Sie an…vorbei."
        ],
        "forbidden": [
            "tense:Futur_I",
            "tense:Präteritum_weak",
