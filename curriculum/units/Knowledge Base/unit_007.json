      "wir",
      "ihr",
      "sie_plural",
      "Sie"
    ],
    "sentence_types": [
      "declarative",
      "w_question",
      "yes_no_question"
    ],
    "new_rules_in_this_unit": [
      "In declarative sentences, place the conjugated verb in second position with the subject in position 1 or 3.",
      "In W-questions, place the question word in position 1, the conjugated verb in position 2, and the subject in position 3.",
      "In yes/no questions, place the conjugated verb in position 1 and the subject in position 2.",
      "Use nicht to negate a sentence: place nicht after the verb in short sentences, and before predicative nouns, adverbs, and places.",
      "Place gern/gerne directly after the conjugated verb, or between the verb and its complement if the verb has one."
    ],
